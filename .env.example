# [CONFIG] n8n Webhook URL
# The destination where all uploaded file data will be sent.
N8N_WEBHOOK_URL="https://your-n8n-instance.com/webhook/..."

# [CONFIG] The public URL of this application
APP_URL="REPLACE_WITH_YOUR_APP_URL"

# [CONFIG] Application Port
PORT=3000

# [OPTIONAL] Webhook Secret
# Sent as X-EverythingDocument-Signature header for verification.
WEBHOOK_SECRET=your_secret_here

# [CONFIG] Chat Webhook URL
# The destination for document-related chat instructions.
CHAT_WEBHOOK_URL="https://your-n8n-instance.com/webhook/chat/..."
